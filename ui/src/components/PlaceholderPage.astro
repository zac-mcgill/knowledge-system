---
// Placeholder page component for future Phase 11+ pages.
interface Props {
  pageTitle: string;
  description?: string;
  phase?: string;
}
const { pageTitle, description = '', phase = '11+' } = Astro.props;
---

<div class="max-w-xl">
  <div class="bg-zinc-900 border border-zinc-800 rounded-lg p-6">
    <div class="flex items-start gap-4">
      <div class="w-10 h-10 bg-zinc-800 border border-zinc-700 rounded-lg flex items-center justify-center shrink-0 mt-0.5">
        <svg class="w-5 h-5 text-zinc-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      <div>
        <h2 class="text-base font-semibold text-zinc-100">{pageTitle}</h2>
        {description && <p class="text-sm text-zinc-400 mt-1">{description}</p>}
        <p class="text-sm text-zinc-600 mt-3">
          Planned for Phase {phase}. The backend API and CLI already support this functionality.
        </p>
        <div class="mt-4 p-3 bg-zinc-950 border border-zinc-800 rounded text-xs text-zinc-500 font-mono">
          # Available via CLI now:<br />
          py run.py {pageTitle.toLowerCase().replace(/\s+/g, '-')}
        </div>
      </div>
    </div>
  </div>
</div>
