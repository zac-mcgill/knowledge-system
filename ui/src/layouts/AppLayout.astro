---
import '../styles/global.css';

// Phase 30B - layout-mode contract. Pages declare which shell mode
// they want via the `layoutMode` prop. The default remains `standard`
// to preserve existing visuals; later sub-phases (30C-30F) flip pages
// to `wide` / `workspace` / `developer` as they migrate.
//
// Modes:
//   standard   - bounded reading column (existing behaviour)
//   wide       - full available content width with sensible gutters
//   workspace  - full-width workbench shell with internal scroll
//   developer  - developer/diagnostics shell mode
export type LayoutMode = 'standard' | 'wide' | 'workspace' | 'developer';

interface Props {
  title?: string;
  layoutMode?: LayoutMode;
}
const { title = 'Context Vault Engine', layoutMode = 'standard' } = Astro.props;
const validLayoutModes: LayoutMode[] = ['standard', 'wide', 'workspace', 'developer'];
const mode: LayoutMode = validLayoutModes.includes(layoutMode) ? layoutMode : 'standard';

// Phase 29B - grouped, data-driven sidebar navigation.
// Every existing /app route remains reachable. Route paths are not
// renamed in Phase 29B. Page consolidation is deferred to Phase 29D.
const navGroups: Array<{
  label: string;
  items: Array<{ label: string; href: string }>;
}> = [
  {
    label: 'Overview',
    items: [
      { label: 'Dashboard', href: '/app/' },
    ],
  },
  {
    label: 'Vault',
    items: [
      { label: 'Setup', href: '/app/vault-setup' },
      { label: 'Notes', href: '/app/notes' },
      { label: 'Import', href: '/app/import' },
    ],
  },
  {
    label: 'Context',
    items: [
      { label: 'Bundles', href: '/app/bundles' },
      { label: 'Exports', href: '/app/exports' },
      { label: 'Graph', href: '/app/graph' },
      { label: 'Controller', href: '/app/controller' },
    ],
  },
  {
    label: 'Review and Governance',
    items: [
      { label: 'Validation', href: '/app/validation' },
      { label: 'Tasks', href: '/app/tasks' },
      { label: 'Security', href: '/app/security' },
      { label: 'Feedback', href: '/app/feedback' },
      { label: 'Pending', href: '/app/pending' },
      { label: 'Trust', href: '/app/trust' },
    ],
  },
  {
    label: 'Developer',
    items: [
      { label: 'API / Raw', href: '/app/raw' },
    ],
  },
];

const currentPath = Astro.url.pathname;
function isActive(href: string): boolean {
  if (href === '/app/') {
    return currentPath === '/app' || currentPath === '/app/';
  }
  return href === currentPath;
}
function groupId(label: string): string {
  return 'nav-group-' + label.toLowerCase().replace(/\s+/g, '-');
}
---

<!doctype html>
<html lang="en" data-theme="dark" style="color-scheme: dark light;">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Context Vault Engine, local-first knowledge vault management" />
    <title>{title} - Context Vault Engine</title>
    <link rel="icon" type="image/svg+xml" href="/app/favicon.svg" />
    <link rel="alternate icon" type="image/png" href="/app/favicon.png" />
    <link rel="apple-touch-icon" href="/app/favicon.png" />
    {/*
      Phase 30F - inline theme bootstrap. This runs synchronously
      before any hydration so the document root has the correct
      data-theme attribute before first paint, avoiding a flash of
      the wrong theme. Default is dark when nothing is stored, which
      preserves the historical Phase 30B-30E behaviour. No new
      dependency is introduced.
    */}
    <script is:inline>
      (function () {
        try {
          var saved = window.localStorage.getItem('cve-theme');
          var theme = saved === 'light' ? 'light' : 'dark';
          document.documentElement.setAttribute('data-theme', theme);
          document.documentElement.style.colorScheme = theme === 'light' ? 'light' : 'dark light';
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      })();
    </script>
    <style>
      /* Phase 29B - visible keyboard focus state for nav links.
         Plain CSS so it works without client-side JS. */
      .cve-nav-link:focus-visible {
        outline: 2px solid var(--cve-focus);
        outline-offset: 2px;
        border-radius: 6px;
      }
      html[data-theme="dark"] .cve-nav-link[aria-current="page"] {
        background-color: rgb(39 39 42);
        color: rgb(244 244 245);
        font-weight: 500;
        box-shadow: inset 2px 0 0 0 var(--cve-accent);
      }
      html[data-theme="light"] .cve-nav-link[aria-current="page"] {
        background-color: var(--cve-surface-muted);
        color: var(--cve-text-strong);
        font-weight: 500;
        box-shadow: inset 2px 0 0 0 var(--cve-accent);
      }
      /* Phase 30F - tokenised app chrome so the light-mode toggle
         produces a coherent surface. The chrome classes below are
         applied alongside Tailwind utilities and override the
         dark-only literals when data-theme="light". */
      .cve-app-chrome-bg {
        background-color: var(--cve-bg);
      }
      .cve-app-chrome-surface {
        background-color: var(--cve-bg);
        color: var(--cve-text);
      }
      .cve-app-chrome-border {
        border-color: var(--cve-border-soft);
      }
      .cve-app-chrome-text-strong { color: var(--cve-text-strong); }
      .cve-app-chrome-text { color: var(--cve-text); }
      .cve-app-chrome-text-muted { color: var(--cve-text-muted); }
      .cve-app-chrome-text-faint { color: var(--cve-text-faint); }
      .cve-app-chrome-nav-item:hover {
        background-color: var(--cve-surface);
        color: var(--cve-text);
      }
      /* Brand logo - swap between dark/light SVG variants based on
         the active data-theme so the logo always reads against the
         current chrome surface. */
      .cve-brand-logo {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        line-height: 0;
        border-radius: 8px;
        outline: none;
      }
      .cve-brand-logo:focus-visible {
        outline: 2px solid var(--cve-focus);
        outline-offset: 2px;
      }
      .cve-brand-logo__img {
        display: block;
        height: auto;
        max-width: 100%;
      }
      .cve-brand-logo--sidebar {
        width: 100%;
      }
      .cve-brand-logo--sidebar .cve-brand-logo__img {
        width: 100%;
        max-width: 220px;
      }
      .cve-brand-logo--mobile .cve-brand-logo__img {
        height: 28px;
        width: auto;
      }
      html[data-theme="dark"] .cve-brand-logo__img--light,
      html[data-theme="light"] .cve-brand-logo__img--dark {
        display: none;
      }
      /* Phase 30F - theme toggle. Plain framework-free control.
         Keyboard reachable via standard button semantics, accessible
         name supplied via inline text. */
      .cve-theme-toggle {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        padding: 0.25rem 0.625rem;
        border-radius: var(--cve-radius);
        border: 1px solid var(--cve-border);
        background-color: var(--cve-surface);
        color: var(--cve-text);
        font-size: 0.75rem;
        line-height: 1;
        cursor: pointer;
        transition: background-color 0.15s, color 0.15s, border-color 0.15s;
      }
      .cve-theme-toggle:hover {
        background-color: var(--cve-surface-muted);
        color: var(--cve-text-strong);
      }
      .cve-theme-toggle:focus-visible {
        outline: 2px solid var(--cve-focus);
        outline-offset: 2px;
      }
      .cve-theme-toggle__dot {
        width: 0.5rem;
        height: 0.5rem;
        border-radius: 999px;
        background-color: var(--cve-accent);
      }
    </style>
  </head>

  <body class="min-h-screen cve-app-chrome-surface">

    <div class="flex min-h-screen">

      <!-- Sidebar -->
      <aside class="hidden md:flex flex-col w-60 shrink-0 cve-app-chrome-bg border-r cve-app-chrome-border">

        <!-- Brand / header -->
        <div class="px-5 py-5 border-b cve-app-chrome-border flex items-center justify-center">
          <a href="/app/" aria-label="Context Vault Engine - home" class="cve-brand-logo cve-brand-logo--sidebar">
            <img src="/app/context-vault-engine-logo-vector.svg" alt="Context Vault Engine" class="cve-brand-logo__img cve-brand-logo__img--dark" width="1017" height="470" />
            <img src="/app/context-vault-engine-logo-vector-light.svg" alt="" aria-hidden="true" class="cve-brand-logo__img cve-brand-logo__img--light" width="1017" height="470" />
          </a>
        </div>

        <!-- Grouped navigation -->
        <nav aria-label="Primary" class="flex-1 py-4 overflow-y-auto">
          {navGroups.map(group => (
            <div class="mb-5 last:mb-0">
              <div id={groupId(group.label)} class="px-5 mb-1.5 text-[11px] font-semibold uppercase tracking-wider cve-app-chrome-text-faint">
                {group.label}
              </div>
              <ul aria-labelledby={groupId(group.label)} class="space-y-0.5 px-2">
                {group.items.map(item => {
                  const active = isActive(item.href);
                  return (
                    <li>
                      <a
                        href={item.href}
                        aria-current={active ? 'page' : undefined}
                        class:list={[
                          'cve-nav-link flex items-center gap-2 px-3 py-1.5 rounded-md text-sm transition-colors',
                          active ? '' : 'cve-app-chrome-text-muted cve-app-chrome-nav-item',
                        ]}
                      >
                        {item.label}
                      </a>
                    </li>
                  );
                })}
              </ul>
            </div>
          ))}
        </nav>

        <!-- Footer -->
        <div class="px-5 py-3 border-t cve-app-chrome-border">
          <span class="text-xs cve-app-chrome-text-faint">Phase 30 - Stable</span>
        </div>
      </aside>

      <!-- Mobile top bar -->
      <div class="md:hidden fixed top-0 left-0 right-0 z-20 cve-app-chrome-bg border-b cve-app-chrome-border flex items-center justify-between px-4 h-12">
        <a href="/app/" aria-label="Context Vault Engine - home" class="cve-brand-logo cve-brand-logo--mobile">
          <img src="/app/context-vault-engine-logo-vector.svg" alt="Context Vault Engine" class="cve-brand-logo__img cve-brand-logo__img--dark" width="1017" height="470" />
          <img src="/app/context-vault-engine-logo-vector-light.svg" alt="" aria-hidden="true" class="cve-brand-logo__img cve-brand-logo__img--light" width="1017" height="470" />
        </a>
        <div class="flex items-center gap-2">
          <span class="text-xs cve-app-chrome-text-faint truncate max-w-[40vw]">{title}</span>
          <button
            type="button"
            id="cve-theme-toggle-mobile"
            class="cve-theme-toggle"
            aria-label="Toggle colour theme (currently dark)"
            data-cve-theme-toggle
          >
            <span class="cve-theme-toggle__dot" aria-hidden="true"></span>
            <span class="cve-theme-toggle__label" data-cve-theme-label>Dark</span>
          </button>
        </div>
      </div>

      <!-- Main content -->
      <main class={`cve-shell-main cve-shell-main--${mode} flex-1 min-w-0 flex flex-col`} data-layout-mode={mode}>

        <!-- Top bar -->
        <div class="hidden md:flex items-center gap-2 px-6 py-3.5 border-b cve-app-chrome-border cve-app-chrome-bg">
          <span class="text-xs cve-app-chrome-text-faint">Context Vault Engine</span>
          <span class="text-xs cve-app-chrome-text-faint" aria-hidden="true">/</span>
          <span class="text-xs cve-app-chrome-text-muted">{title}</span>
          <div class="ml-auto flex items-center gap-2">
            <button
              type="button"
              id="cve-theme-toggle"
              class="cve-theme-toggle"
              aria-label="Toggle colour theme (currently dark)"
              data-cve-theme-toggle
            >
              <span class="cve-theme-toggle__dot" aria-hidden="true"></span>
              <span class="cve-theme-toggle__label" data-cve-theme-label>Dark</span>
            </button>
          </div>
        </div>

        <!-- Page content -->
        <div class={`cve-shell-content cve-shell-content--${mode} flex-1 p-4 md:p-6 pt-16 md:pt-6 overflow-auto`} data-layout-mode={mode}>
          <slot />
        </div>
      </main>

    </div>

    {/*
      Phase 30F - theme toggle behaviour. Framework-free; runs after
      the inline bootstrap. Updates data-theme on <html>, persists
      to localStorage, and keeps the button's accessible name and
      visible label in sync with the current theme.
    */}
    <script is:inline>
      (function () {
        var STORAGE_KEY = 'cve-theme';
        function applyTheme(theme, persist) {
          var t = theme === 'light' ? 'light' : 'dark';
          document.documentElement.setAttribute('data-theme', t);
          try { document.documentElement.style.colorScheme = t === 'light' ? 'light' : 'dark light'; } catch (e) {}
          if (persist) {
            try { window.localStorage.setItem(STORAGE_KEY, t); } catch (e) {}
          }
          var labelText = t === 'light' ? 'Light' : 'Dark';
          var ariaText = 'Toggle colour theme (currently ' + (t === 'light' ? 'light' : 'dark') + ')';
          var labels = document.querySelectorAll('[data-cve-theme-label]');
          for (var i = 0; i < labels.length; i++) {
            labels[i].textContent = labelText;
          }
          var buttons = document.querySelectorAll('[data-cve-theme-toggle]');
          for (var j = 0; j < buttons.length; j++) {
            buttons[j].setAttribute('aria-label', ariaText);
            buttons[j].setAttribute('aria-pressed', t === 'light' ? 'true' : 'false');
          }
        }
        function readCurrent() {
          var attr = document.documentElement.getAttribute('data-theme');
          return attr === 'light' ? 'light' : 'dark';
        }
        // Sync the toggle label to whatever the bootstrap script applied.
        applyTheme(readCurrent(), false);
        function onClick() {
          var next = readCurrent() === 'light' ? 'dark' : 'light';
          applyTheme(next, true);
        }
        var buttons = document.querySelectorAll('[data-cve-theme-toggle]');
        for (var i = 0; i < buttons.length; i++) {
          buttons[i].addEventListener('click', onClick);
        }
      })();
    </script>
  </body>
</html>
