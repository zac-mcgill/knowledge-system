---
import '../styles/global.css';

interface Props {
  title?: string;
}
const { title = 'Context Vault Engine' } = Astro.props;

// Phase 29B - grouped, data-driven sidebar navigation.
// Every existing /app route remains reachable. Route paths are not
// renamed in Phase 29B. Page consolidation is deferred to Phase 29D.
const navGroups: Array<{
  label: string;
  items: Array<{ label: string; href: string }>;
}> = [
  {
    label: 'Overview',
    items: [
      { label: 'Dashboard', href: '/app/' },
    ],
  },
  {
    label: 'Vault',
    items: [
      { label: 'Setup', href: '/app/vault-setup' },
      { label: 'Notes', href: '/app/notes' },
      { label: 'Import', href: '/app/import' },
    ],
  },
  {
    label: 'Context',
    items: [
      { label: 'Bundles', href: '/app/bundles' },
      { label: 'Exports', href: '/app/exports' },
      { label: 'Graph', href: '/app/graph' },
      { label: 'Controller', href: '/app/controller' },
    ],
  },
  {
    label: 'Review and Governance',
    items: [
      { label: 'Validation', href: '/app/validation' },
      { label: 'Tasks', href: '/app/tasks' },
      { label: 'Security', href: '/app/security' },
      { label: 'Feedback', href: '/app/feedback' },
      { label: 'Pending', href: '/app/pending' },
      { label: 'Trust', href: '/app/trust' },
    ],
  },
  {
    label: 'Developer',
    items: [
      { label: 'API / Raw', href: '/app/raw' },
    ],
  },
];

const currentPath = Astro.url.pathname;
function isActive(href: string): boolean {
  if (href === '/app/') {
    return currentPath === '/app' || currentPath === '/app/';
  }
  return href === currentPath;
}
function groupId(label: string): string {
  return 'nav-group-' + label.toLowerCase().replace(/\s+/g, '-');
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Context Vault Engine, local-first knowledge vault management" />
    <title>{title} - Context Vault Engine</title>
    <link rel="icon" type="image/svg+xml" href="/app/favicon.svg" />
    <style>
      /* Phase 29B - visible keyboard focus state for nav links.
         Plain CSS so it works without client-side JS. */
      .cve-nav-link:focus-visible {
        outline: 2px solid #38bdf8;
        outline-offset: 2px;
        border-radius: 6px;
      }
      .cve-nav-link[aria-current="page"] {
        background-color: rgb(39 39 42);
        color: rgb(244 244 245);
        font-weight: 500;
        box-shadow: inset 2px 0 0 0 #38bdf8;
      }
    </style>
  </head>

  <body class="min-h-screen bg-zinc-950 text-zinc-100">

    <div class="flex min-h-screen">

      <!-- Sidebar -->
      <aside class="hidden md:flex flex-col w-60 shrink-0 bg-zinc-950 border-r border-zinc-800">

        <!-- Brand / header -->
        <div class="px-5 py-5 border-b border-zinc-800">
          <div class="text-base font-semibold text-zinc-100 tracking-tight">Context Vault</div>
          <div class="text-xs text-zinc-500 mt-0.5 tracking-wide uppercase">Engine</div>
        </div>

        <!-- Grouped navigation -->
        <nav aria-label="Primary" class="flex-1 py-4 overflow-y-auto">
          {navGroups.map(group => (
            <div class="mb-5 last:mb-0">
              <div id={groupId(group.label)} class="px-5 mb-1.5 text-[11px] font-semibold uppercase tracking-wider text-zinc-500">
                {group.label}
              </div>
              <ul aria-labelledby={groupId(group.label)} class="space-y-0.5 px-2">
                {group.items.map(item => {
                  const active = isActive(item.href);
                  return (
                    <li>
                      <a
                        href={item.href}
                        aria-current={active ? 'page' : undefined}
                        class:list={[
                          'cve-nav-link flex items-center gap-2 px-3 py-1.5 rounded-md text-sm transition-colors',
                          active ? '' : 'text-zinc-400 hover:text-zinc-100 hover:bg-zinc-900',
                        ]}
                      >
                        {item.label}
                      </a>
                    </li>
                  );
                })}
              </ul>
            </div>
          ))}
        </nav>

        <!-- Footer -->
        <div class="px-5 py-3 border-t border-zinc-800">
          <span class="text-xs text-zinc-500">Phase 29B - Navigation</span>
        </div>
      </aside>

      <!-- Mobile top bar -->
      <div class="md:hidden fixed top-0 left-0 right-0 z-20 bg-zinc-950 border-b border-zinc-800 flex items-center justify-between px-4 h-12">
        <div class="flex flex-col leading-tight">
          <span class="text-sm font-semibold text-zinc-100">Context Vault</span>
          <span class="text-[10px] text-zinc-500 uppercase tracking-wide">Engine</span>
        </div>
        <span class="text-xs text-zinc-500 truncate max-w-[50%]">{title}</span>
      </div>

      <!-- Main content -->
      <main class="flex-1 min-w-0 flex flex-col">

        <!-- Top bar -->
        <div class="hidden md:flex items-center gap-2 px-6 py-3.5 border-b border-zinc-800 bg-zinc-950">
          <span class="text-xs text-zinc-500">Context Vault Engine</span>
          <span class="text-xs text-zinc-700">/</span>
          <span class="text-xs text-zinc-300">{title}</span>
        </div>

        <!-- Page content -->
        <div class="flex-1 p-4 md:p-6 pt-16 md:pt-6 overflow-auto">
          <slot />
        </div>
      </main>

    </div>
  </body>
</html>
