---
import '../styles/global.css';

interface Props {
  title?: string;
}
const { title = 'Context Vault Engine' } = Astro.props;

const navItems = [
  { label: 'Dashboard', href: '/app/', active: false },
  { label: 'Vault Setup', href: '/app/vault-setup', active: false },
  { label: 'Notes', href: '/app/notes', active: false },
  { label: 'Validation', href: '/app/validation', active: false },
  { label: 'Tasks', href: '/app/tasks', active: false },
  { label: 'Bundles', href: '/app/bundles', active: false },
  { label: 'Security', href: '/app/security', active: false },
  { label: 'Exports', href: '/app/exports', active: false },
  { label: 'Feedback', href: '/app/feedback', active: false },
  { label: 'API / Raw', href: '/app/raw', active: false },
];

// Determine active item from current path
const currentPath = Astro.url.pathname;
const activeItems = navItems.map(item => ({
  ...item,
  active: item.href === currentPath ||
    (item.href === '/app/' && (currentPath === '/app' || currentPath === '/app/')),
}));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Context Vault Engine — local-first knowledge vault management" />
    <title>{title} — Context Vault Engine</title>
    <link rel="icon" type="image/svg+xml" href="/app/favicon.svg" />
  </head>

  <body class="min-h-screen bg-zinc-950 text-zinc-100">

    <!-- Outer layout: sidebar + main -->
    <div class="flex min-h-screen">

      <!-- ── Sidebar ──────────────────────────────────────────── -->
      <aside class="hidden md:flex flex-col w-56 shrink-0 bg-zinc-950 border-r border-zinc-800">

        <!-- Logo / brand -->
        <div class="flex items-center gap-2.5 px-4 py-4 border-b border-zinc-800">
          <div class="w-6 h-6 bg-sky-500 rounded flex items-center justify-center shrink-0">
            <svg class="w-3.5 h-3.5 text-white" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd" />
            </svg>
          </div>
          <div class="min-w-0">
            <div class="text-sm font-semibold text-zinc-100 truncate">Context Vault</div>
            <div class="text-xs text-zinc-500">Engine</div>
          </div>
        </div>

        <!-- Navigation -->
        <nav class="flex-1 py-3 overflow-y-auto">
          <ul class="space-y-0.5 px-2">
            {activeItems.map(item => (
              <li>
                <a
                  href={item.href}
                  class:list={[
                    'flex items-center gap-2 px-2.5 py-2 rounded-md text-sm transition-colors',
                    item.active
                      ? 'bg-zinc-800 text-zinc-100 font-medium'
                      : 'text-zinc-400 hover:text-zinc-200 hover:bg-zinc-900',
                    // Placeholder items are visually de-emphasised but still navigable
                    item.label !== 'Dashboard' && !item.active ? 'opacity-60' : '',
                  ]}
                >
                  {item.label}
                  {item.label !== 'Dashboard' && (
                    <span class="ml-auto text-xs text-zinc-700 font-mono">soon</span>
                  )}
                </a>
              </li>
            ))}
          </ul>
        </nav>

        <!-- Footer: version badge -->
        <div class="px-4 py-3 border-t border-zinc-800">
          <span class="text-xs text-zinc-600">Phase 10 — UI Foundation</span>
        </div>
      </aside>

      <!-- ── Mobile top bar (replaces sidebar on small screens) ── -->
      <div class="md:hidden fixed top-0 left-0 right-0 z-20 bg-zinc-950 border-b border-zinc-800 flex items-center justify-between px-4 h-12">
        <div class="flex items-center gap-2">
          <div class="w-5 h-5 bg-sky-500 rounded flex items-center justify-center">
            <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd" />
            </svg>
          </div>
          <span class="text-sm font-semibold text-zinc-100">Context Vault Engine</span>
        </div>
        <span class="text-xs text-zinc-600">{title}</span>
      </div>

      <!-- ── Main content ─────────────────────────────────────── -->
      <main class="flex-1 min-w-0 flex flex-col">

        <!-- Top bar (breadcrumb / page title) -->
        <div class="hidden md:flex items-center gap-2 px-6 py-3.5 border-b border-zinc-800 bg-zinc-950">
          <span class="text-xs text-zinc-600">Context Vault Engine</span>
          <span class="text-xs text-zinc-700">/</span>
          <span class="text-xs text-zinc-400">{title}</span>
        </div>

        <!-- Page content -->
        <div class="flex-1 p-4 md:p-6 pt-16 md:pt-6 overflow-auto">
          <slot />
        </div>
      </main>

    </div>
  </body>
</html>
